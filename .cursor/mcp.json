{
  "mcpServers": {
    "nextjs": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-nextjs"
      ],
      "env": {
        "NEXTJS_PROJECT_PATH": "/workspace"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    }
  }
}
